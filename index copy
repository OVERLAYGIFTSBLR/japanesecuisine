<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sakura Kitchen — AR Menu</title>
  <meta name="description" content="Interactive AR menu for Sakura Kitchen — authentic Japanese cuisine with 3D dish previews." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />

  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #1a1208;
      --paper:     #fdf8f0;
      --surface:   #fff9f2;
      --accent:    #c0392b;
      --gold:      #b8860b;
      --muted:     #7a6a55;
      --border:    rgba(139,100,50,0.15);
      --border-md: rgba(139,100,50,0.28);
      --tag-veg:   #2d6a4f;
      --tag-new:   #c0392b;
      --tag-dotd:  #b8860b;
      --shadow:    0 4px 20px rgba(26,18,8,0.07);
      --shadow-lg: 0 12px 48px rgba(26,18,8,0.16);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--paper);
      font-family: 'DM Sans', sans-serif;
      color: var(--ink);
      min-height: 100vh;
    }

    /* ── HEADER ─────────────────────────────────────── */
    .site-header {
      background: var(--ink);
      color: #fff;
      text-align: center;
      padding: 2.5rem 1rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .site-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 50%, rgba(192,57,43,0.12) 0%, transparent 60%),
        radial-gradient(circle at 80% 50%, rgba(184,134,11,0.10) 0%, transparent 60%);
      pointer-events: none;
    }

    .header-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 13px;
      letter-spacing: 5px;
      color: rgba(255,255,255,0.45);
      margin-bottom: 10px;
    }

    .header-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 6vw, 52px);
      font-weight: 400;
      letter-spacing: -0.5px;
      line-height: 1.05;
      margin-bottom: 8px;
    }

    .header-title em { font-style: italic; color: rgba(255,255,255,0.7); }

    .header-sub {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 18px;
    }

    .ar-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 11px;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.7);
    }

    .ar-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #e74c3c;
      flex-shrink: 0;
      animation: pulse 1.6s ease-in-out infinite;
    }

    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.35;transform:scale(0.8)} }

    /* ── CATEGORY TABS ───────────────────────────────── */
    .tabs-wrap {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--paper);
      border-bottom: 1px solid var(--border);
      padding: 0 1rem;
    }

    .tabs-inner {
      max-width: 720px;
      margin: 0 auto;
      display: flex;
      gap: 4px;
      overflow-x: auto;
      scrollbar-width: none;
      padding: 10px 0;
    }

    .tabs-inner::-webkit-scrollbar { display: none; }

    .tab-btn {
      flex-shrink: 0;
      padding: 7px 18px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.18s ease;
      white-space: nowrap;
    }

    .tab-btn:hover { border-color: var(--border-md); color: var(--ink); }

    .tab-btn.active {
      background: var(--ink);
      color: #fff;
      border-color: var(--ink);
    }

    /* ── MAIN CONTENT ────────────────────────────────── */
    .main {
      max-width: 720px;
      margin: 0 auto;
      padding: 1.5rem 1rem 4rem;
    }

    /* ── LOADING / ERROR STATES ──────────────────────── */
    .state-box {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--muted);
    }

    .state-box .spinner {
      width: 32px; height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--ink);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 1rem;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .state-box p { font-size: 14px; }

    /* ── SECTION DIVIDER ─────────────────────────────── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 1.5rem 0 0.75rem;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .section-label span { flex: 1; height: 1px; background: var(--border); }

    /* ── MENU ITEMS ──────────────────────────────────── */
    .items-grid { display: flex; flex-direction: column; gap: 10px; }

    .menu-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.1rem 1.25rem;
      cursor: pointer;
      transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
      -webkit-tap-highlight-color: transparent;
    }

    .menu-card:hover {
      border-color: var(--border-md);
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .card-row { display: flex; gap: 14px; align-items: flex-start; }

    .card-thumb {
      width: 64px; height: 64px;
      flex-shrink: 0;
      border-radius: 10px;
      background: linear-gradient(135deg, #f5ead6 0%, #e8d5b0 100%);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      position: relative;
    }

    .ar-pill {
      position: absolute;
      bottom: 3px; right: 3px;
      background: var(--ink);
      color: #fff;
      font-size: 8px;
      letter-spacing: 0.5px;
      padding: 2px 5px;
      border-radius: 5px;
      font-family: 'DM Sans', sans-serif;
      line-height: 1.4;
    }

    .card-body { flex: 1; min-width: 0; }

    .name-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 3px;
    }

    .dish-name {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      font-weight: 400;
      color: var(--ink);
    }

    .dish-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 12px;
      color: var(--muted);
    }

    .tags-row { display: flex; gap: 4px; flex-wrap: wrap; margin: 5px 0 7px; }

    .tag {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 500;
      letter-spacing: 0.3px;
    }

    .tag-veg  { background: #d6f0e4; color: var(--tag-veg); }
    .tag-new  { background: #fde8e8; color: var(--tag-new); }
    .tag-dotd { background: #fef3d0; color: var(--tag-dotd); }

    .dish-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
      margin-bottom: 8px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .dish-price {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      color: var(--ink);
    }

    .price-sym {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      color: var(--muted);
      margin-right: 1px;
    }

    .ar-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 8px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      letter-spacing: 0.3px;
      cursor: pointer;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
    }

    .ar-btn:hover { opacity: 0.78; }
    .ar-btn svg { width: 13px; height: 13px; flex-shrink: 0; }

    /* ── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(8,6,2,0.72);
      z-index: 9000;
      align-items: flex-end;
      justify-content: center;
      padding: 0;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }

    @media (min-width: 540px) {
      .modal-overlay { align-items: center; padding: 1.5rem; }
    }

    .modal-overlay.open { display: flex; }

    .modal-card {
      background: var(--paper);
      border-radius: 20px 20px 0 0;
      width: 100%;
      max-width: 500px;
      max-height: 92vh;
      overflow-y: auto;
      overscroll-behavior: contain;
      position: relative;
      animation: slideUp 0.25s ease;
    }

    @media (min-width: 540px) {
      .modal-card { border-radius: 20px; animation: fadeIn 0.2s ease; }
    }

    @keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @keyframes fadeIn  { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }

    .modal-viewer-wrap {
      width: 100%;
      height: 280px;
      background: linear-gradient(160deg, #1c140a 0%, #2e2112 100%);
      border-radius: 20px 20px 0 0;
      position: relative;
      overflow: hidden;
    }

    @media (min-width: 540px) {
      .modal-viewer-wrap { border-radius: 20px 20px 0 0; }
    }

    model-viewer {
      width: 100%;
      height: 100%;
      background: transparent;
      --progress-bar-color: var(--gold);
    }

    .modal-close {
      position: absolute;
      top: 12px; right: 12px;
      width: 34px; height: 34px;
      border-radius: 50%;
      background: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.8);
      font-size: 17px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      z-index: 10;
      line-height: 1;
      transition: background 0.15s;
    }

    .modal-close:hover { background: rgba(255,255,255,0.25); }

    .viewer-hint {
      position: absolute;
      bottom: 10px; left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.35);
      pointer-events: none;
      white-space: nowrap;
    }

    .modal-body { padding: 1.4rem 1.5rem 1.8rem; }

    .modal-name {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 400;
      margin-bottom: 4px;
    }

    .modal-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    .modal-desc {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.7;
      padding-left: 12px;
      border-left: 2px solid var(--border);
      margin-bottom: 18px;
    }

    .modal-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }

    .modal-price {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
    }

    /* ── FOOTER ──────────────────────────────────────── */
    .site-footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 11px;
      letter-spacing: 1px;
      color: var(--muted);
      border-top: 1px solid var(--border);
      line-height: 1.8;
    }

    /* ── UNAVAILABLE DIMMING ─────────────────────────── */
    .menu-card.unavailable { opacity: 0.45; pointer-events: none; }


  </style>
</head>
<body>

<header class="site-header">
  <div id="language-picker" style="margin-bottom: 15px; position: relative; z-index: 10;">
    <select id="lang-select" style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.3); border-radius: 5px; padding: 6px 10px; font-family: 'DM Sans', sans-serif; font-size: 12px;">
      <option value="en">English</option>
      <option value="jp">日本語 (Japanese)</option>
      <option value="kn">ಕನ್ನಡ (Kannada)</option>
      <option value="ta">தமிழ் (Tamil)</option>
