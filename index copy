      <button id="ar-capture-btn" class="ar-btn" style="width: 100%; margin-bottom: 15px; justify-content: center; background: #c0392b; height: 45px; font-weight: 600;">
        📸 Capture & Share
      </button>

      <h2 class="modal-name" id="modal-name"></h2>
      <p class="modal-jp" id="modal-jp"></p>
      <div class="tags-row" id="modal-tags"></div>
      <p class="modal-desc" id="modal-desc"></p>
      <div class="modal-footer">
        <div class="modal-price" id="modal-price"></div>
        <div class="tags-row" id="modal-tags2"></div>
      </div>
    </div>
  </div>
</div>

<footer class="site-footer">
  Tap any dish to view in 3D &nbsp;·&nbsp; Prices in ₹ &nbsp;·&nbsp; 🌿 Vegetarian friendly<br>
  <span style="opacity:0.5">AR requires a compatible mobile device</span>
</footer>

<script>
  // ─────────────────────────────────────────────────────────────
  //  CONFIG — update SHEET_ID with your Google Sheet ID
  //  Make sure the sheet is published:
  //    File → Share → Publish to web → CSV
  // ─────────────────────────────────────────────────────────────
  const SHEET_ID  = '1QAReLCzWLQEfNyY9V6Cg5VbGPqmbXh4XCZ_RCQSRlz0';
  const SHEET_GID = '0'; // change if your data is on a different tab

  const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SHEET_GID}`;

  // ── Emoji map (fallback when no image) ───────────────────────
  const EMOJI_MAP = {
    gyoza: '🥟', edamame: '🫘', karaage: '🍗', 'miso soup': '🍵',
    takoyaki: '🐙', 'agedashi tofu': '🫕', ramen: '🍜',
    'salmon sashimi': '🐟', tempura: '🍤', 'matcha-ice-cream': '🍦',
  };

  const translations = {
    en: { sub: "Authentic Japanese Cuisine", badge: "Interactive 3D & AR Preview", veg: "veg", capture: "Capture & Share", loading: "Loading menu...", suffix: "" },
    jp: { sub: "本物の日本料理", badge: "インタラクティブ3DとARプレビュー", veg: "ベジ", capture: "キャプチャして共有", loading: "読み込み中...", suffix: "_jp" },
    kn: { sub: "ಅಧಿಕೃತ ಜಪಾನೀಸ್ ಆಹಾರ", badge: "ಸಂವಾದಾತ್ಮಕ 3D ಮತ್ತು AR ಮುನ್ನೋಟ", veg: "ಸಸ್ಯಹಾರಿ", capture: "ಸೆರೆಹಿಡಿಯಿರಿ ಮತ್ತು ಹಂಚಿಕೊಳ್ಳಿ", loading: "ಲೋಡ್ ಆಗುತ್ತಿದೆ...", suffix: "_kn" },
    ta: { sub: "உண்மையான ஜப்பானிய உணவு", badge: "ஊடாடும் 3D மற்றும் AR மாதிரிக்காட்சி", veg: "சைவம்", capture: "பிடிப்பு மற்றும் பகிர்வு", loading: "ஏற்றப்படுகிறது...", suffix: "_ta" },
    ml: { sub: "ആധികാരിക ജാപ്പനീസ് വിഭവങ്ങൾ", badge: "ഇന്ററാക്ടീവ് 3D & AR പ്രിവ്യൂ", veg: "വെജിറ്റേറിയൻ", capture: "പകർത്തുക, പങ്കികൊള്ളുക", loading: "ലോഡ് ചെയ്യുന്നു...", suffix: "_ml" },
    te: { sub: "ప్రామాణిక జపనీస్ వంటకాలు", badge: "ఇంటరాక్టివ్ 3D & AR ప్రివ్యూ", veg: "శాఖాహారం", capture: "క్యాప్చర్ చేసి షేర్ చేయండి", loading: "లోడ్ అవుతోంది...", suffix: "_te" }
  };

  const CATEGORY_LABELS = {
    all: { en: 'All', kn: 'ಎಲ್ಲವೂ', ml: 'എല്ലാം', ta: 'அனைத்தும்', te: 'అన్నీ', jp: 'すべて' },
    starter: { en: 'Starters', kn: 'ಆರಂಭಿಕಗಳು', ml: 'സ്റ്റാർട്ടറുകൾ', ta: 'துவக்கிகள்', te: 'ప్రారంభకాలు', jp: 'スターター' },
    ramen: { en: 'Ramen', kn: 'ರಾಮೆನ್', ml: 'രാമെൻ', ta: 'ராமன்', te: 'రామెన్', jp: 'ラーメン' },
    sushi: { en: 'Sushi', kn: 'ಸುಶಿ', ml: 'സുഷി', ta: 'சுஷி', te: 'సుషీ', jp: '寿司' },
    rice: { en: 'Mains', kn: 'ಮುಖ್ಯ ಆಹಾರ', ml: 'പ്രധാന ഭക്ഷണം', ta: 'முக்கிய உணவு', te: 'ప్రధాన వంటకాలు', jp: 'メイン' },
    drinks: { en: 'Desserts & Drinks', kn: 'ಪಾನೀಯಗಳು', ml: 'പാനീയങ്ങൾ', ta: 'பானங்கள்', te: 'పానీయాలు', jp: 'デザートとドリンク' }
  };

  let allDishes = [];
  let rawRows = [];
  let activeCategory = 'all';
  let currentLang = 'en';

  // ─────────────────────────────────────────────────────────────
  //  CSV PARSER
  // ─────────────────────────────────────────────────────────────
  function parseCSV(text) {
    const lines = text.trim().split('\n');
    if (lines.length < 2) return [];
    const headers = splitCSVLine(lines[0]).map(h => h.trim().toLowerCase());
    return lines.slice(1).map(line => {
      const vals = splitCSVLine(line);
      const obj = {};
      headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
      return obj;
    });
  }

  function splitCSVLine(line) {
    const result = []; let cur = ''; let inQ = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"' && !inQ) { inQ = true; continue; }
      if (ch === '"' && inQ) {
        if (line[i+1] === '"') { cur += '"'; i++; } else { inQ = false; }
        continue;
      }
      if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
      cur += ch;
    }
    result.push(cur);
    return result;
  }

  // ─────────────────────────────────────────────────────────────
  //  NORMALISE ROW → dish object with Multi-Lang support
  // ─────────────────────────────────────────────────────────────
  function rowToDish(row) {
    const truthy = v => ['true','yes','1'].includes((v||'').toLowerCase());
    
    const getVal = (baseField) => {
      const langSuffix = translations[currentLang].suffix;
      return row[baseField + langSuffix] || row[baseField] || '';
    };

    const name = getVal('name');
    const emoji = EMOJI_MAP[row['name'] ? row['name'].toLowerCase() : ''] || '🍽️';

    return {
      id:          row['id']       || '',
      name,
      category:    (row['category']|| row['cat'] || 'other').toLowerCase(),
      jp:          row['name_jp']  || row['jp_name'] || '',
      desc:        getVal('description') || getVal('desc'),
      price:       parseInt(row['price'] || '0', 10),
      veg:         truthy(row['veg']),
      dotd:        truthy(row['dish of the day'] || row['dotd']),
      isNew:       truthy(row['new']),
      available:   truthy(row['available']),
      glb:         row['glb_url']  || row['glb_url'] || '',
      scale:       parseFloat(row['scale'] || '0.22') || 0.22,
      emoji,
    };
  }

  // ─────────────────────────────────────────────────────────────
  //  RENDER LOGIC
  // ─────────────────────────────────────────────────────────────
  function renderTabs(dishes) {
    const cats = ['all', ...new Set(dishes.map(d => d.category))];
    const wrap = document.getElementById('tabs-inner');
    wrap.innerHTML = cats.map(c => {
      const label = CATEGORY_LABELS[c] ? CATEGORY_LABELS[c][currentLang] : c;
      return `<button class="tab-btn${c === activeCategory ? ' active' : ''}" data-cat="${c}">${label}</button>`;
    }).join('');
    wrap.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.cat;
        renderTabs(allDishes);
        renderItems(allDishes);
      });
    });
  }

  function tagHTML(d) {
    return [
      d.veg   ? `<span class="tag tag-veg">🌿 ${translations[currentLang].veg}</span>` : '',
      d.isNew ? '<span class="tag tag-new">new</span>' : '',
      d.dotd  ? '<span class="tag tag-dotd">★ chef\'s pick</span>' : '',
    ].join('');
  }

  function renderItems(dishes) {
    const filtered = activeCategory === 'all'
      ? dishes
      : dishes.filter(d => d.category === activeCategory);

    const container = document.getElementById('items-container');

    if (activeCategory === 'all') {
      const grouped = {};
      filtered.forEach(d => {
        if (!grouped[d.category]) grouped[d.category] = [];
        grouped[d.category].push(d);
      });

      container.innerHTML = Object.entries(grouped).map(([cat, items]) => {
        const label = CATEGORY_LABELS[cat] ? CATEGORY_LABELS[cat][currentLang] : cat;
        return `
          <div class="section-label"><span></span>${label}<span></span></div>
          <div class="items-grid">${items.map(cardHTML).join('')}</div>
        `;
      }).join('');
    } else {
      container.innerHTML = `<div class="items-grid">${filtered.map(cardHTML).join('')}</div>`;
    }

    container.querySelectorAll('.menu-card').forEach(card => {
      card.addEventListener('click', () => openModal(card.dataset.id));
    });
  }

  function cardHTML(d) {
    return `
      <div class="menu-card${d.available ? '' : ' unavailable'}" data-id="${d.id}" role="button" tabindex="0" aria-label="View ${d.name} in 3D">
        <div class="card-row">
          <div class="card-thumb">
            <span>${d.emoji}</span>
            ${d.glb ? '<span class="ar-pill">AR</span>' : ''}
          </div>
          <div class="card-body">
            <div class="name-row">
              <span class="dish-name">${d.name}</span>
            </div>
            <div class="tags-row">${tagHTML(d)}</div>
            <p class="dish-desc">${d.desc}</p>
            <div class="card-footer">
              <div class="dish-price"><span class="price-sym">₹</span>${d.price.toLocaleString('en-IN')}</div>
              ${d.glb
                ? `<button class="ar-btn" data-id="${d.id}" aria-label="View ${d.name} in 3D">
                     <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                     AR
                   </button>`
                : ''}
            </div>
          </div>
        </div>
      </div>`;
  }

  // ─────────────────────────────────────────────────────────────
  //  MODAL & AR LOGIC
  // ─────────────────────────────────────────────────────────────
  function openModal(id) {
    const d = allDishes.find(x => x.id === id);
    if (!d) return;

    document.getElementById('modal-name').textContent = d.name;
    document.getElementById('modal-jp').textContent   = d.jp;
    document.getElementById('modal-desc').textContent = d.desc;
    document.getElementById('modal-price').innerHTML  =
      `<span style="font-family:'DM Sans',sans-serif;font-size:14px;color:var(--muted)">₹</span>${d.price.toLocaleString('en-IN')}`;
    document.getElementById('modal-tags').innerHTML   = tagHTML(d);
    document.getElementById('modal-tags2').innerHTML  = tagHTML(d);

    const viewerWrap = document.getElementById('modal-viewer-wrap');
    const oldMV = viewerWrap.querySelector('model-viewer');
    if (oldMV) oldMV.remove();

    if (d.glb) {
      const mv = document.createElement('model-viewer');
      const cleanGlb = d.glb.replace(/ /g, '-'); // fix space issue
const usdz = cleanGlb.replace('.glb', '.usdz');

mv.setAttribute('src', cleanGlb);
mv.setAttribute('ios-src', usdz); // ✅ iOS FIX
      mv.setAttribute('ar', '');
      mv.setAttribute('ar-modes', 'webxr quick-look scene-viewer');
      mv.setAttribute('ar-placement', 'floor');
      mv.setAttribute('ar-scale', 'fixed');
      mv.setAttribute('shadow-intensity', '1.5');
      mv.setAttribute('shadow-softness', '1');
      mv.setAttribute('environment-image', 'neutral');
      mv.setAttribute('exposure', '1');
      mv.setAttribute('camera-controls', '');
      mv.setAttribute('auto-rotate', '');
      
      const s = d.scale;
      mv.setAttribute('scale', `${s} ${s} ${s}`);
      
      mv.style.cssText = 'width:100%;height:100%;background:transparent;';
      viewerWrap.insertBefore(mv, viewerWrap.querySelector('.viewer-hint'));
      setTimeout(() => {
  if (mv.canActivateAR) {
    mv.activateAR(); // auto open AR
  }
}, 500);
    }

    document.getElementById('modal-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);

  // ─────────────────────────────────────────────────────────────
  //  UI ACTIONS
  // ─────────────────────────────────────────────────────────────
  document.getElementById('lang-select').addEventListener('change', (e) => {
    currentLang = e.target.value;
    const t = translations[currentLang];
    document.getElementById('ui-sub-tag').textContent = t.sub;
    document.getElementById('ui-ar-badge').textContent = t.badge;
    document.getElementById('ar-capture-btn').textContent = "📸 " + t.capture;
    document.getElementById('ui-loading').textContent = t.loading;
    
    processData();
  });

  document.getElementById('ar-capture-btn').addEventListener('click', async () => {
    const mv = document.querySelector('model-viewer');
    if (!mv) {
      alert("Please open a 3D model first!");
      return;
    }
    try {
      const blob = await mv.toBlob({ idealAspect: true });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `Sakura_AR_${Date.now()}.png`;
      a.click();
      alert("Photo saved to your gallery!");
    } catch (err) {
      console.error("Capture failed", err);
    }
  });

  // ─────────────────────────────────────────────────────────────
  //  INIT
  // ─────────────────────────────────────────────────────────────
  function processData() {
    allDishes = rawRows.map(rowToDish).filter(d => d.name);
    renderTabs(allDishes);
    renderItems(allDishes);
  }

  async function init() {
    const loading = document.getElementById('loading-state');
    const container = document.getElementById('items-container');

    try {
      const res = await fetch(CSV_URL);
      const text = await res.text();
      rawRows = parseCSV(text);
      
      loading.style.display = 'none';
      container.style.display = 'block';
      
      processData();
    } catch (err) {
      console.error('Menu load error:', err);
    }
  }

  init();
</script>
</body>
</html>