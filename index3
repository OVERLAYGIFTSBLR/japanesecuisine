<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sakura Kitchen — AR Menu</title>
  <meta name="description" content="Interactive AR menu for Sakura Kitchen — authentic Japanese cuisine with 3D dish previews." />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />

  <!-- Model Viewer for AR/3D -->
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #1a1208;
      --paper:     #fdf8f0;
      --surface:   #fff9f2;
      --accent:    #c0392b;
      --gold:      #b8860b;
      --muted:     #7a6a55;
      --border:    rgba(139,100,50,0.15);
      --border-md: rgba(139,100,50,0.28);
      --tag-veg:   #2d6a4f;
      --tag-new:   #c0392b;
      --tag-dotd:  #b8860b;
      --shadow:    0 4px 20px rgba(26,18,8,0.07);
      --shadow-lg: 0 12px 48px rgba(26,18,8,0.16);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--paper);
      font-family: 'DM Sans', sans-serif;
      color: var(--ink);
      min-height: 100vh;
    }

    /* ── HEADER ─────────────────────────────────────── */
    .site-header {
      background: var(--ink);
      color: #fff;
      text-align: center;
      padding: 2.5rem 1rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .site-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 50%, rgba(192,57,43,0.12) 0%, transparent 60%),
        radial-gradient(circle at 80% 50%, rgba(184,134,11,0.10) 0%, transparent 60%);
      pointer-events: none;
    }

    .header-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 13px;
      letter-spacing: 5px;
      color: rgba(255,255,255,0.45);
      margin-bottom: 10px;
    }

    .header-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 6vw, 52px);
      font-weight: 400;
      letter-spacing: -0.5px;
      line-height: 1.05;
      margin-bottom: 8px;
    }

    .header-title em { font-style: italic; color: rgba(255,255,255,0.7); }

    .header-sub {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 18px;
    }

    .ar-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 11px;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.7);
    }

    .ar-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #e74c3c;
      flex-shrink: 0;
      animation: pulse 1.6s ease-in-out infinite;
    }

    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.35;transform:scale(0.8)} }

    /* ── CATEGORY TABS ───────────────────────────────── */
    .tabs-wrap {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--paper);
      border-bottom: 1px solid var(--border);
      padding: 0 1rem;
    }

    .tabs-inner {
      max-width: 720px;
      margin: 0 auto;
      display: flex;
      gap: 4px;
      overflow-x: auto;
      scrollbar-width: none;
      padding: 10px 0;
    }

    .tabs-inner::-webkit-scrollbar { display: none; }

    .tab-btn {
      flex-shrink: 0;
      padding: 7px 18px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.18s ease;
      white-space: nowrap;
    }

    .tab-btn:hover { border-color: var(--border-md); color: var(--ink); }

    .tab-btn.active {
      background: var(--ink);
      color: #fff;
      border-color: var(--ink);
    }

    /* ── MAIN CONTENT ────────────────────────────────── */
    .main {
      max-width: 720px;
      margin: 0 auto;
      padding: 1.5rem 1rem 4rem;
    }

    /* ── LOADING / ERROR STATES ──────────────────────── */
    .state-box {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--muted);
    }

    .state-box .spinner {
      width: 32px; height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--ink);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 1rem;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .state-box p { font-size: 14px; }

    /* ── SECTION DIVIDER ─────────────────────────────── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 1.5rem 0 0.75rem;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .section-label span { flex: 1; height: 1px; background: var(--border); }

    /* ── MENU ITEMS ──────────────────────────────────── */
    .items-grid { display: flex; flex-direction: column; gap: 10px; }

    .menu-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.1rem 1.25rem;
      cursor: pointer;
      transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
      -webkit-tap-highlight-color: transparent;
    }

    .menu-card:hover {
      border-color: var(--border-md);
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .card-row { display: flex; gap: 14px; align-items: flex-start; }

    .card-thumb {
      width: 64px; height: 64px;
      flex-shrink: 0;
      border-radius: 10px;
      background: linear-gradient(135deg, #f5ead6 0%, #e8d5b0 100%);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      position: relative;
    }

    .ar-pill {
      position: absolute;
      bottom: 3px; right: 3px;
      background: var(--ink);
      color: #fff;
      font-size: 8px;
      letter-spacing: 0.5px;
      padding: 2px 5px;
      border-radius: 5px;
      font-family: 'DM Sans', sans-serif;
      line-height: 1.4;
    }

    .card-body { flex: 1; min-width: 0; }

    .name-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 3px;
    }

    .dish-name {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      font-weight: 400;
      color: var(--ink);
    }

    .dish-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 12px;
      color: var(--muted);
    }

    .tags-row { display: flex; gap: 4px; flex-wrap: wrap; margin: 5px 0 7px; }

    .tag {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 500;
      letter-spacing: 0.3px;
    }

    .tag-veg  { background: #d6f0e4; color: var(--tag-veg); }
    .tag-new  { background: #fde8e8; color: var(--tag-new); }
    .tag-dotd { background: #fef3d0; color: var(--tag-dotd); }

    .dish-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
      margin-bottom: 8px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .dish-price {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      color: var(--ink);
    }

    .price-sym {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      color: var(--muted);
      margin-right: 1px;
    }

    .ar-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 8px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      letter-spacing: 0.3px;
      cursor: pointer;
      transition: opacity 0.15s;
      -webkit-tap-highlight-color: transparent;
    }

    .ar-btn:hover { opacity: 0.78; }
    .ar-btn svg { width: 13px; height: 13px; flex-shrink: 0; }

    /* ── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(8,6,2,0.72);
      z-index: 9000;
      align-items: flex-end;
      justify-content: center;
      padding: 0;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }

    @media (min-width: 540px) {
      .modal-overlay { align-items: center; padding: 1.5rem; }
    }

    .modal-overlay.open { display: flex; }

    .modal-card {
      background: var(--paper);
      border-radius: 20px 20px 0 0;
      width: 100%;
      max-width: 500px;
      max-height: 92vh;
      overflow-y: auto;
      overscroll-behavior: contain;
      position: relative;
      animation: slideUp 0.25s ease;
    }

    @media (min-width: 540px) {
      .modal-card { border-radius: 20px; animation: fadeIn 0.2s ease; }
    }

    @keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @keyframes fadeIn  { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }

    .modal-viewer-wrap {
      width: 100%;
      height: 280px;
      background: linear-gradient(160deg, #1c140a 0%, #2e2112 100%);
      border-radius: 20px 20px 0 0;
      position: relative;
      overflow: hidden;
    }

    @media (min-width: 540px) {
      .modal-viewer-wrap { border-radius: 20px 20px 0 0; }
    }

    model-viewer {
      width: 100%;
      height: 100%;
      background: transparent;
      --progress-bar-color: var(--gold);
    }

    .modal-close {
      position: absolute;
      top: 12px; right: 12px;
      width: 34px; height: 34px;
      border-radius: 50%;
      background: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.8);
      font-size: 17px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      z-index: 10;
      line-height: 1;
      transition: background 0.15s;
    }

    .modal-close:hover { background: rgba(255,255,255,0.25); }

    .viewer-hint {
      position: absolute;
      bottom: 10px; left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.35);
      pointer-events: none;
      white-space: nowrap;
    }

    .modal-body { padding: 1.4rem 1.5rem 1.8rem; }

    .modal-name {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 400;
      margin-bottom: 4px;
    }

    .modal-jp {
      font-family: 'Noto Serif JP', serif;
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    .modal-desc {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.7;
      padding-left: 12px;
      border-left: 2px solid var(--border);
      margin-bottom: 18px;
    }

    .modal-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }

    .modal-price {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
    }

    /* ── FOOTER ──────────────────────────────────────── */
    .site-footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 11px;
      letter-spacing: 1px;
      color: var(--muted);
      border-top: 1px solid var(--border);
      line-height: 1.8;
    }

    /* ── UNAVAILABLE DIMMING ─────────────────────────── */
    .menu-card.unavailable { opacity: 0.45; pointer-events: none; }
  </style>
</head>
<body>

<!-- ═══════════════════ HEADER ═══════════════════════ -->
<header class="site-header">
  <p class="header-jp">日本料理</p>
  <h1 class="header-title">Sakura <em>Kitchen</em></h1>
  <p class="header-sub">Authentic Japanese Cuisine</p>
  <span class="ar-badge"><span class="ar-dot"></span> Interactive 3D &amp; AR Preview</span>
</header>

<!-- ═══════════════════ TABS ════════════════════════ -->
<nav class="tabs-wrap" aria-label="Menu categories">
  <div class="tabs-inner" id="tabs-inner"></div>
</nav>

<!-- ═══════════════════ MAIN ════════════════════════ -->
<main class="main" id="main-content">
  <div class="state-box" id="loading-state">
    <div class="spinner"></div>
    <p>Loading menu…</p>
  </div>
  <div id="items-container" style="display:none"></div>
</main>

<!-- ═══════════════════ MODAL ════════════════════════ -->
<div class="modal-overlay" id="modal-overlay" role="dialog" aria-modal="true" aria-label="Dish detail">
  <div class="modal-card" id="modal-card">
    <div class="modal-viewer-wrap" id="modal-viewer-wrap">
      <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
      <span class="viewer-hint">drag to rotate · pinch to zoom · AR places dish on surface</span>
    </div>
    <div class="modal-body">
      <h2 class="modal-name" id="modal-name"></h2>
      <p class="modal-jp" id="modal-jp"></p>
      <div class="tags-row" id="modal-tags"></div>
      <p class="modal-desc" id="modal-desc"></p>
      <div class="modal-footer">
        <div class="modal-price" id="modal-price"></div>
        <div class="tags-row" id="modal-tags2"></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════ FOOTER ═══════════════════════ -->
<footer class="site-footer">
  Tap any dish to view in 3D &nbsp;·&nbsp; Prices in ₹ &nbsp;·&nbsp; 🌿 Vegetarian friendly<br>
  <span style="opacity:0.5">AR requires a compatible mobile device</span>
</footer>

<script>
  // ─────────────────────────────────────────────────────────────
  //  CONFIG — update SHEET_ID with your Google Sheet ID
  //  Make sure the sheet is published:
  //    File → Share → Publish to web → CSV
  // ─────────────────────────────────────────────────────────────
  const SHEET_ID  = '1QAReLCzWLQEfNyY9V6Cg5VbGPqmbXh4XCZ_RCQSRlz0';
  const SHEET_GID = '0'; // change if your data is on a different tab (check URL: ...gid=XXXXX)

  const CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SHEET_GID}`;

  // ── Emoji map (fallback when no image) ───────────────────────
  const EMOJI_MAP = {
    gyoza: '🥟', edamame: '🫘', karaage: '🍗', 'miso soup': '🍵',
    takoyaki: '🐙', 'agedashi tofu': '🫕', ramen: '🍜',
    'salmon sashimi': '🐟', tempura: '🍤', 'matcha ice cream': '🍦',
  };

  const CATEGORY_LABELS = {
    all: 'All', starter: 'Starters', ramen: 'Ramen',
    sushi: 'Sushi', rice: 'Mains', drinks: 'Desserts & Drinks',
  };

  // ─────────────────────────────────────────────────────────────
  //  CSV PARSER (handles quoted fields with commas)
  // ─────────────────────────────────────────────────────────────
  function parseCSV(text) {
    const lines = text.trim().split('\n');
    if (lines.length < 2) return [];
    const headers = splitCSVLine(lines[0]).map(h => h.trim().toLowerCase());
    return lines.slice(1).map(line => {
      const vals = splitCSVLine(line);
      const obj = {};
      headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
      return obj;
    });
  }

  function splitCSVLine(line) {
    const result = []; let cur = ''; let inQ = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"' && !inQ) { inQ = true; continue; }
      if (ch === '"' && inQ) {
        if (line[i+1] === '"') { cur += '"'; i++; } else { inQ = false; }
        continue;
      }
      if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
      cur += ch;
    }
    result.push(cur);
    return result;
  }

  // ─────────────────────────────────────────────────────────────
  //  NORMALISE ROW → dish object
  // ─────────────────────────────────────────────────────────────
  function rowToDish(row) {
    const truthy = v => ['true','yes','1'].includes((v||'').toLowerCase());
    const name   = row['name'] || row['dish name'] || '';
    const emoji  = EMOJI_MAP[name.toLowerCase()] || '🍽️';
    return {
      id:          row['id']       || '',
      name,
      category:    (row['category']|| row['cat'] || 'other').toLowerCase(),
      jp:          row['jp_name']  || row['jp name'] || '',
      desc:        row['description'] || '',
      price:       parseInt(row['price'] || '0', 10),
      veg:         truthy(row['veg']),
      dotd:        truthy(row['dish of the day'] || row['dotd']),
      isNew:       truthy(row['new']),
      available:   truthy(row['available']),
      glb:         row['glb_url']  || row['glb url'] || '',
      emoji,
    };
  }

  // ─────────────────────────────────────────────────────────────
  //  STATE
  // ─────────────────────────────────────────────────────────────
  let allDishes = [];
  let activeCategory = 'all';

  // ─────────────────────────────────────────────────────────────
  //  RENDER TABS
  // ─────────────────────────────────────────────────────────────
  function renderTabs(dishes) {
    const cats = ['all', ...new Set(dishes.map(d => d.category))];
    const wrap = document.getElementById('tabs-inner');
    wrap.innerHTML = cats.map(c => {
      const label = CATEGORY_LABELS[c] || (c.charAt(0).toUpperCase() + c.slice(1));
      return `<button class="tab-btn${c === activeCategory ? ' active' : ''}" data-cat="${c}">${label}</button>`;
    }).join('');
    wrap.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.cat;
        renderTabs(allDishes);
        renderItems(allDishes);
      });
    });
  }

  // ─────────────────────────────────────────────────────────────
  //  RENDER ITEMS
  // ─────────────────────────────────────────────────────────────
  function tagHTML(d) {
    return [
      d.veg   ? '<span class="tag tag-veg">🌿 veg</span>' : '',
      d.isNew ? '<span class="tag tag-new">new</span>' : '',
      d.dotd  ? '<span class="tag tag-dotd">★ chef\'s pick</span>' : '',
    ].join('');
  }

  function renderItems(dishes) {
    const filtered = activeCategory === 'all'
      ? dishes
      : dishes.filter(d => d.category === activeCategory);

    const container = document.getElementById('items-container');

    // Group by category if "All" tab
    if (activeCategory === 'all') {
      const grouped = {};
      filtered.forEach(d => {
        if (!grouped[d.category]) grouped[d.category] = [];
        grouped[d.category].push(d);
      });

      container.innerHTML = Object.entries(grouped).map(([cat, items]) => {
        const label = CATEGORY_LABELS[cat] || (cat.charAt(0).toUpperCase() + cat.slice(1));
        return `
          <div class="section-label"><span></span>${label}<span></span></div>
          <div class="items-grid">${items.map(cardHTML).join('')}</div>
        `;
      }).join('');
    } else {
      container.innerHTML = `<div class="items-grid">${filtered.map(cardHTML).join('')}</div>`;
    }

    container.querySelectorAll('.menu-card').forEach(card => {
      card.addEventListener('click', () => openModal(card.dataset.id));
    });
    container.querySelectorAll('.ar-btn').forEach(btn => {
      btn.addEventListener('click', e => { e.stopPropagation(); openModal(btn.dataset.id); });
    });
  }

  function cardHTML(d) {
    return `
      <div class="menu-card${d.available ? '' : ' unavailable'}" data-id="${d.id}" role="button" tabindex="0" aria-label="View ${d.name} in 3D">
        <div class="card-row">
          <div class="card-thumb">
            <span>${d.emoji}</span>
            ${d.glb ? '<span class="ar-pill">AR</span>' : ''}
          </div>
          <div class="card-body">
            <div class="name-row">
              <span class="dish-name">${d.name}</span>
              ${d.jp ? `<span class="dish-jp">${d.jp}</span>` : ''}
            </div>
            <div class="tags-row">${tagHTML(d)}</div>
            <p class="dish-desc">${d.desc}</p>
            <div class="card-footer">
              <div class="dish-price"><span class="price-sym">₹</span>${d.price.toLocaleString('en-IN')}</div>
              ${d.glb
                ? `<button class="ar-btn" data-id="${d.id}" aria-label="View ${d.name} in 3D">
                     <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                     View in AR
                   </button>`
                : ''}
            </div>
          </div>
        </div>
      </div>`;
  }

  // ─────────────────────────────────────────────────────────────
  //  MODAL
  // ─────────────────────────────────────────────────────────────
  function openModal(id) {
    const d = allDishes.find(x => x.id === id);
    if (!d) return;

    document.getElementById('modal-name').textContent = d.name;
    document.getElementById('modal-jp').textContent   = d.jp;
    document.getElementById('modal-desc').textContent = d.desc;
    document.getElementById('modal-price').innerHTML  =
      `<span style="font-family:'DM Sans',sans-serif;font-size:14px;color:var(--muted)">₹</span>${d.price.toLocaleString('en-IN')}`;
    document.getElementById('modal-tags').innerHTML   = tagHTML(d);
    document.getElementById('modal-tags2').innerHTML  = tagHTML(d);

    const viewerWrap = document.getElementById('modal-viewer-wrap');
    // Clear old model-viewer
    const oldMV = viewerWrap.querySelector('model-viewer');
    if (oldMV) oldMV.remove();

    if (d.glb) {
      const mv = document.createElement('model-viewer');
      mv.setAttribute('src', d.glb);
      mv.setAttribute('alt', `${d.name} 3D model`);
      mv.setAttribute('auto-rotate', '');
      mv.setAttribute('camera-controls', '');
      mv.setAttribute('ar', '');
      mv.setAttribute('ar-modes', 'webxr scene-viewer quick-look');
      mv.setAttribute('loading', 'lazy');

      // ── FIX 1: Lock physical size in AR ───────────────────────
      // ar-scale="fixed" tells WebXR not to rescale the model —
      // it will always appear at the size set by the scale attribute.
      // scale="0.25 0.25 0.25" = ~25 cm plate (1 GLTF unit = 1 metre).
      // Adjust scale value if your GLB is already at real-world size:
      //   real-world-scale GLB  → use scale="1 1 1"
      //   oversized GLB (e.g. 1 unit = 1 cm) → use scale="0.01 0.01 0.01"
      mv.setAttribute('ar-scale', 'fixed');
      mv.setAttribute('scale', '0.25 0.25 0.25');

      // ── FIX 2: Anchor model to surface, stop camera-tracking ──
      // ar-placement="floor" anchors to a detected horizontal surface
      // (table, countertop) so the model stays put when you move the camera.
      // camera-orbit locks the 3D preview to a stable angle so the dish
      // doesn't drift in the modal viewer either.
      mv.setAttribute('ar-placement', 'floor');
      mv.setAttribute('xr-environment', '');
      mv.setAttribute('camera-orbit', '0deg 75deg 1.5m');
      mv.setAttribute('min-camera-orbit', 'auto 10deg auto');
      mv.setAttribute('max-camera-orbit', 'auto 90deg auto');

      // ── Prevent touch-events leaking into page scroll during AR ─
      mv.setAttribute('interaction-prompt', 'none');
      mv.setAttribute('touch-action', 'none');

      mv.style.cssText = 'width:100%;height:280px;background:transparent;';
      viewerWrap.insertBefore(mv, viewerWrap.querySelector('.viewer-hint'));
    } else {
      // No GLB — show emoji placeholder
      const ph = document.createElement('div');
      ph.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;height:280px;gap:8px;';
      ph.innerHTML = `<span style="font-size:64px">${d.emoji}</span><span style="font-size:11px;letter-spacing:1px;color:rgba(255,255,255,0.35)">3D model not available</span>`;
      viewerWrap.insertBefore(ph, viewerWrap.querySelector('.viewer-hint'));
    }

    document.getElementById('modal-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
    // Pause any playing model
    const mv = document.querySelector('#modal-viewer-wrap model-viewer');
    if (mv) mv.pause();
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('modal-overlay').addEventListener('click', e => {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // ─────────────────────────────────────────────────────────────
  //  FETCH & INIT
  // ─────────────────────────────────────────────────────────────
  async function init() {
    const loading = document.getElementById('loading-state');
    const container = document.getElementById('items-container');

    try {
      const res = await fetch(CSV_URL);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const text = await res.text();
      const rows = parseCSV(text);
      allDishes = rows.map(rowToDish).filter(d => d.name);

      if (allDishes.length === 0) throw new Error('No dishes found in sheet.');

      loading.style.display = 'none';
      container.style.display = 'block';
      renderTabs(allDishes);
      renderItems(allDishes);

    } catch (err) {
      console.error('Menu load error:', err);
      loading.innerHTML = `
        <p style="color:#c0392b;font-weight:500;margin-bottom:8px">Could not load menu data</p>
        <p style="font-size:13px;line-height:1.6">
          Make sure your Google Sheet is published:<br>
          <strong>File → Share → Publish to web → CSV</strong><br><br>
          Sheet ID in use: <code style="background:#f0e8d8;padding:2px 6px;border-radius:4px;font-size:12px">${SHEET_ID}</code>
        </p>`;
    }
  }

  init();
</script>
</body>
</html>
