    const res  = await fetch(SHEET_URL);
    const text = await res.text();
    const m    = text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
    if (!m) throw 0;
    const json = JSON.parse(m[1]);
    const cols = json.table.cols.map(c => c.label.toLowerCase().trim());
    const get  = (r, col) => {
      const i = cols.indexOf(col);
      return (i >= 0 && r.c[i] && r.c[i].v != null) ? String(r.c[i].v).trim() : '';
    };
    menuItems = json.table.rows.filter(r => r && r.c).map((r, i) => ({
      id: get(r,'id') || 'i'+i,
      name: get(r,'name'),
      jp: get(r,'jp_name'),
      category: get(r,'category'),
      desc_en: get(r,'desc_en') || get(r,'description'),
      desc_jp: get(r,'desc_jp'), desc_hi: get(r,'desc_hi'), desc_kn: get(r,'desc_kn'), desc_ta: get(r,'desc_ta'), desc_ml: get(r,'desc_ml'), desc_te: get(r,'desc_te'),
      name_hi: get(r,'name_hi'), name_kn: get(r,'name_kn'), name_ta: get(r,'name_ta'), name_ml: get(r,'name_ml'), name_te: get(r,'name_te'),
      price: parseInt(get(r,'price')) || 0,
      emoji: get(r,'emoji') || '🍽️',
      veg: get(r,'veg').toLowerCase() === 'yes',
      chef_pick: get(r,'chef_pick').toLowerCase() === 'yes',
      new: get(r,'new').toLowerCase() === 'yes',
      available: get(r,'available').toLowerCase() !== 'no',
      glb_url: get(r,'glb_url'),
    })).filter(i => i.name);
  } catch(e) { console.warn("Sheet fetch failed, using internal memory."); }
  buildMenu();
}

function buildCards() {
  const t = T[currentLang], font = getFont();
  const track = document.getElementById('cardTrack');
  track.innerHTML = '';
  track.style.height = (menuItems.length * viewH) + 'px';
  menuItems.forEach((item, idx) => {
    const pills = [];
    if (item.veg) pills.push(`<span class="info-pill pill-veg">${t.vegPill}</span>`);
    if (item.chef_pick) pills.push(`<span class="info-pill pill-chef">★ ${t.chefPill}</span>`);
    if (item.new) pills.push(`<span class="info-pill pill-new">${t.newPill}</span>`);
    const has3d = !!(item.glb_url && item.glb_url.trim());
    const nativeName = getNativeName(item);
    const desc = getDesc(item);
    const nameEn = currentLang === 'jp' ? (item.jp || item.name) : item.name;
    const fs = font ? `font-family:${font};` : '';
    const card = document.createElement('div');
    card.className = 'dish-card';
    card.style.cssText = `top:${idx*viewH}px;height:${viewH}px;`;
    card.innerHTML = `
      <div class="dish-bg"></div>
      <div class="dish-viewer">
        ${has3d ? `<model-viewer id="mv_${idx}" src="${item.glb_url}" ar ar-modes="webxr scene-viewer quick-look" camera-controls shadow-intensity="1.2" exposure="1.1" environment-image="neutral" style="width:100%;height:100%;background:transparent;"></model-viewer>` : `<div class="viewer-no-model"><div class="viewer-no-emoji">${item.emoji}</div><div class="viewer-no-txt">${t.noModel}</div></div>`}
        <div class="viewer-badge"><div class="vb-dot"></div><div class="vb-txt">${has3d ? t.drag3d : t.preview}</div></div>
      </div>
      <div class="dish-info">
        <div class="info-category">${item.category}</div>
        <div class="info-names"><div class="info-name-en">${nameEn}</div>${nativeName ? `<div class="info-name-native" style="${fs}">${nativeName}</div>` : ''}</div>
        <div class="info-desc" style="${fs}">${desc}</div>
        <div class="info-meta"><div class="info-price">₹ ${item.price.toLocaleString('en-IN')}</div><div class="info-pills">${pills.join('')}</div></div>
      </div>
      <div class="dish-actions">
        <button class="btn-add-cart" onclick="addToCart('${item.id}',${idx})">
          <div class="btn-cart-counter" id="cartCounter_${idx}">0</div>
          <div class="btn-add-cart-text"><div class="btn-add-cart-main">${t.addToCart}</div></div>
        </button>
      </div>`;
    track.appendChild(card);
  });
}

function buildMenu() {
  viewH = window.innerHeight; totalScrollH = (menuItems.length-1)*viewH;
  buildCards(); initSliderDrag(); initScrollArea(); startRafLoop();
  document.getElementById('globalLoader').style.display='none';
  document.getElementById('app').style.display='flex';
}

function startRafLoop(){
  function loop(){
    const diff=targetY-scrollY; scrollY+=diff*0.1;
    document.getElementById('cardTrack').style.transform=`translateY(${-scrollY}px)`;
    syncSliderVisual(); requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}

function initSliderDrag(){
  const wrap=document.getElementById('sliderTrackWrap');
  wrap.addEventListener('pointerdown',e=>{sliderDragging=true;});
  window.addEventListener('pointerup',()=>{sliderDragging=false;});
  wrap.addEventListener('pointermove',e=>{if(!sliderDragging)return;const r=wrap.getBoundingClientRect();const p=Math.max(0,Math.min(1,(e.clientY-r.top)/r.height));targetY=p*totalScrollH;});
}

function syncSliderVisual(){
  const p=totalScrollH>0?scrollY/totalScrollH:0;
  const thumb=document.getElementById('sliderThumb');
  if(thumb) thumb.style.top=(p*(viewH-200))+'px';
}

function initScrollArea(){
  const area=document.getElementById('scrollArea');
  area.addEventListener('wheel',e=>{targetY=Math.max(0,Math.min(totalScrollH,targetY+e.deltaY));});
  let sy=0;
  area.addEventListener('touchstart',e=>{sy=e.touches[0].clientY;});
  area.addEventListener('touchmove',e=>{const dy=sy-e.touches[0].clientY;sy=e.touches[0].clientY;targetY=Math.max(0,Math.min(totalScrollH,targetY+dy));});
}

function addToCart(id,idx){
  cart[id]=(cart[id]||0)+1;
  const c=document.getElementById('cartCounter_'+idx);
  if(c){c.textContent=cart[id];c.classList.add('show');}
  updateCartUI();
}
function updateCartUI(){
  const n=Object.values(cart).reduce((a,b)=>a+b,0);
  const el=document.getElementById('hudCartCount');
  el.textContent=n; el.classList.toggle('show',n>0);
}

function openOrder(){document.getElementById('screenOrder').classList.add('show');}
function closeOrder(){document.getElementById('screenOrder').classList.remove('show');}
function openFunZone(){document.getElementById('fzOverlay').classList.add('show');}
function closeFunZone(){document.getElementById('fzOverlay').classList.remove('show');}

function wcToggle(){
  const m=document.getElementById('wcMenu');
  m.classList.toggle('hidden');
}

// Initializer
setTimeout(()=>{
  document.getElementById('splash').classList.add('out');
  fetchMenu();
}, 2000);

</script>

</body>
